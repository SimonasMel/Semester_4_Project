@inject CarService Garage
@inject FrontEnd.Services.ThemeService Theme
@implements IDisposable

<div class="contents">
    <!-- Left sidebar for medium+ screens -->
    <aside class="hidden md:flex fixed top-0 left-0 bottom-0 w-[260px] flex-col bg-white border-r border-slate-200 p-6 gap-6 overflow-y-auto z-50 transition-colors duration-300 dark:bg-bg-dark dark:border-slate-800">
        <div class="text-2xl font-extrabold tracking-wider text-text-dark dark:text-text-light">Dingger</div>

        <nav class="flex flex-col gap-1.5">
            <NavLink href="/" Match="NavLinkMatch.All" class="flex items-center gap-2.5 px-4 py-2.5 rounded-xl text-slate-500 transition-all duration-200 hover:bg-gray-100 hover:text-text-dark [&.active]:bg-primary/10 [&.active]:text-primary [&.active]:font-bold dark:text-slate-400 dark:hover:bg-slate-800 dark:hover:text-text-light dark:[&.active]:bg-primary/20 dark:[&.active]:text-primary text-[0.95rem]">
                <span class="bi bi-house-door text-lg"></span>
                <span class="link-text">Explore</span>
            </NavLink>

            <NavLink href="/matches" class="flex items-center gap-2.5 px-4 py-2.5 rounded-xl text-slate-500 transition-all duration-200 hover:bg-gray-100 hover:text-text-dark [&.active]:bg-primary/10 [&.active]:text-primary [&.active]:font-bold dark:text-slate-400 dark:hover:bg-slate-800 dark:hover:text-text-light dark:[&.active]:bg-primary/20 dark:[&.active]:text-primary text-[0.95rem] relative">
                <span class="bi bi-heart text-lg"></span>
                <span class="link-text">Matches</span>
                @if (Garage?.MatchedCars?.Count > 0)
                {
                    <span class="absolute right-3 bg-primary text-[#022c22] rounded-full px-2 py-0.5 text-[0.7rem] font-black">@Garage.MatchedCars.Count</span>
                }
            </NavLink>

            <NavLink href="/profile" class="flex items-center gap-2.5 px-4 py-2.5 rounded-xl text-slate-500 transition-all duration-200 hover:bg-gray-100 hover:text-text-dark [&.active]:bg-primary/10 [&.active]:text-primary [&.active]:font-bold dark:text-slate-400 dark:hover:bg-slate-800 dark:hover:text-text-light dark:[&.active]:bg-primary/20 dark:[&.active]:text-primary text-[0.95rem]">
                <span class="bi bi-person text-lg"></span>
                <span class="link-text">Profile</span>
            </NavLink>
            <NavLink href="/comparison" class="flex items-center gap-2.5 px-4 py-2.5 rounded-xl text-slate-500 transition-all duration-200 hover:bg-gray-100 hover:text-text-dark [&.active]:bg-primary/10 [&.active]:text-primary [&.active]:font-bold dark:text-slate-400 dark:hover:bg-slate-800 dark:hover:text-text-light dark:[&.active]:bg-primary/20 dark:[&.active]:text-primary text-[0.95rem]">
                <span class="bi bi-columns-gap text-lg"></span>
                <span class="link-text">Compare</span>
            </NavLink>
        </nav>

        <div class="mt-auto pt-4 border-t border-slate-100 dark:border-slate-800 flex flex-col gap-2">
            <button class="w-full flex items-center gap-2.5 px-4 py-2.5 rounded-xl border border-slate-200 bg-gray-50 text-text-dark cursor-pointer transition-all duration-200 font-bold hover:bg-gray-100 dark:border-slate-700 dark:bg-slate-800/40 dark:text-text-light dark:hover:bg-slate-800 text-[0.85rem]" @onclick="ToggleThemeAsync">
                <span class="bi @(Theme.IsDark ? "bi-brightness-high" : "bi-moon") text-lg"></span>
                <span class="link-text uppercase tracking-wider">
                    @(Theme.IsDark ? "Light Mode" : "Dark Mode")
                </span>
            </button>
        </div>
    </aside>

    <!-- Bottom nav for small screens -->
    <div class="flex md:hidden fixed bottom-0 left-0 right-0 h-[70px] bg-white dark:bg-bg-dark border-t border-slate-200 dark:border-slate-800 justify-around items-center px-4 z-50">
        <NavLink href="/" Match="NavLinkMatch.All" class="flex flex-col items-center gap-1 text-gray-500 dark:text-gray-400 text-[0.75rem] no-underline [&.active]:text-primary [&.active]:font-bold">
            <span class="bi bi-house-door"></span>
            <small>Explore</small>
        </NavLink>

        <NavLink href="/matches" class="flex flex-col items-center gap-1 text-gray-500 dark:text-gray-400 text-[0.75rem] no-underline [&.active]:text-primary [&.active]:font-bold relative">
            <span class="bi bi-heart"></span>
            <small>Matches</small>
            @if (Garage?.MatchedCars?.Count > 0)
            {
                <span class="absolute -top-1 -right-1 bg-primary text-[#022c22] rounded-full w-4 h-4 flex items-center justify-center text-[0.6rem] font-bold">@Garage.MatchedCars.Count</span>
            }
        </NavLink>

        <NavLink href="/profile" class="flex flex-col items-center gap-1 text-gray-500 dark:text-gray-400 text-[0.75rem] no-underline [&.active]:text-primary [&.active]:font-bold">
            <span class="bi bi-person-circle"></span>
            <small>Profile</small>
        </NavLink>

        <NavLink href="/comparison" class="flex flex-col items-center gap-1 text-gray-500 dark:text-gray-400 text-[0.75rem] no-underline [&.active]:text-primary [&.active]:font-bold">
            <span class="bi bi-columns-gap"></span>
            <small>Compare</small>
        </NavLink>
    </div>

@code {
    protected override void OnInitialized()
    {
        Garage.OnChange += StateHasChanged;
        Theme.OnChange += StateHasChanged;
    }

    private async Task ToggleThemeAsync()
    {
        await Theme.ToggleAsync();
    }

    public void Dispose()
    {
        Garage.OnChange -= StateHasChanged;
        Theme.OnChange -= StateHasChanged;
    }
}
</div>
