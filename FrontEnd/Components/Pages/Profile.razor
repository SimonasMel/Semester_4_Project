@page "/profile"

<div class="max-w-4xl mx-auto p-6">

    <h2 class="text-3xl font-bold mb-8 text-primary">Profile Settings</h2>

    <div class="bg-white dark:bg-surface-dark p-8 rounded-2xl shadow-light-soft dark:shadow-soft border border-slate-200 dark:border-slate-800 flex gap-10 md:flex-col">

        <div class="flex-shrink-0 w-1/3 md:w-full">
            <img src="https://images.unsplash.com/photo-1503376780353-7e6692767b70" class="w-full h-auto rounded-xl object-cover shadow-lg border border-slate-100 dark:border-slate-800" />
        </div>

        <div class="flex-grow flex flex-col gap-6">
            <h3 class="text-xl font-bold text-text-dark dark:text-text-light">Your Car</h3>

            <div class="flex flex-col gap-2">
                <label class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">Brand</label>
                <input class="bg-gray-50 dark:bg-slate-800/40 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-text-dark dark:text-text-light focus:border-primary focus:ring-2 focus:ring-primary/10 focus:outline-none transition-all duration-200 font-medium" placeholder="BMW" />
            </div>

            <div class="flex flex-col gap-2">
                <label class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">Model</label>
                <input class="bg-gray-50 dark:bg-slate-800/40 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-text-dark dark:text-text-light focus:border-primary focus:ring-2 focus:ring-primary/10 focus:outline-none transition-all duration-200 font-medium" placeholder="M3" />
            </div>

            <div class="flex flex-col gap-2">
                <label class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">Year</label>
                <input class="bg-gray-50 dark:bg-slate-800/40 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-text-dark dark:text-text-light focus:border-primary focus:ring-2 focus:ring-primary/10 focus:outline-none transition-all duration-200 font-medium" placeholder="2020" />
            </div>

            <div class="flex flex-col gap-2">
                <label class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">Mileage</label>
                <input class="bg-gray-50 dark:bg-slate-800/40 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-text-dark dark:text-text-light focus:border-primary focus:ring-2 focus:ring-primary/10 focus:outline-none transition-all duration-200 font-medium" placeholder="45000 km" />
            </div>

            <button class="mt-4 px-8 py-3 bg-primary text-[#022c22] rounded-full font-bold hover:bg-green-400 transition-all duration-200 shadow-lg shadow-primary/20 active:scale-[0.98]">
                Save Changes
            </button>

        </div>

    </div>

</div>
