@page "/profile"
@inject CarService Garage
@inject NavigationManager Nav

<div class="max-w-4xl mx-auto p-6">

    <h2 class="text-3xl font-bold mb-8 text-primary">My Profile</h2>

    <!-- Notifications -->
    @if (!string.IsNullOrEmpty(SuccessMessage))
    {
        <div class="mb-6 p-4 bg-green-50 dark:bg-green-950 border border-green-200 dark:border-green-800 rounded-xl text-green-800 dark:text-green-200 flex items-center justify-between">
            <span>✓ @SuccessMessage</span>
            <button @onclick="() => SuccessMessage = null" class="text-green-600 hover:text-green-800 font-bold">×</button>
        </div>
    }

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="mb-6 p-4 bg-red-50 dark:bg-red-950 border border-red-200 dark:border-red-800 rounded-xl text-red-800 dark:text-red-200 flex items-center justify-between">
            <span>✗ @ErrorMessage</span>
            <button @onclick="() => ErrorMessage = null" class="text-red-600 hover:text-red-800 font-bold">×</button>
        </div>
    }

    <!-- Add Car Form -->
    <div class="bg-white dark:bg-surface-dark p-8 rounded-2xl shadow-light-soft dark:shadow-soft border border-slate-200 dark:border-slate-800 mb-8">
        <h3 class="text-xl font-bold mb-6 text-text-dark dark:text-text-light">Add a New Car</h3>

        <form @onsubmit="AddCar" class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="flex flex-col gap-2">
                <label class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">Brand</label>
                <input @bind="NewCar.Brand" class="bg-gray-50 dark:bg-slate-800/40 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-text-dark dark:text-text-light focus:border-primary focus:ring-2 focus:ring-primary/10 focus:outline-none transition-all duration-200 font-medium" placeholder="e.g., BMW" required />
            </div>

            <div class="flex flex-col gap-2">
                <label class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">Model</label>
                <input @bind="NewCar.Model" class="bg-gray-50 dark:bg-slate-800/40 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-text-dark dark:text-text-light focus:border-primary focus:ring-2 focus:ring-primary/10 focus:outline-none transition-all duration-200 font-medium" placeholder="e.g., M3" required />
            </div>

            <div class="flex flex-col gap-2">
                <label class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">Production Year</label>
                <input @bind="NewCar.ProductionYear" type="number" min="1980" max="2026" class="bg-gray-50 dark:bg-slate-800/40 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-text-dark dark:text-text-light focus:border-primary focus:ring-2 focus:ring-primary/10 focus:outline-none transition-all duration-200 font-medium" placeholder="2020" required />
            </div>

            <div class="flex flex-col gap-2">
                <label class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">Price (€)</label>
                <input @bind="NewCar.Price" type="number" min="100" max="1000000" step="100" class="bg-gray-50 dark:bg-slate-800/40 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-text-dark dark:text-text-light focus:border-primary focus:ring-2 focus:ring-primary/10 focus:outline-none transition-all duration-200 font-medium" placeholder="50000" required />
            </div>

            <div class="flex flex-col gap-2">
                <label class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">Mileage (km)</label>
                <input @bind="NewCar.MileageKm" type="number" min="0" max="1000000" class="bg-gray-50 dark:bg-slate-800/40 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-text-dark dark:text-text-light focus:border-primary focus:ring-2 focus:ring-primary/10 focus:outline-none transition-all duration-200 font-medium" placeholder="45000" required />
            </div>

            <div class="flex flex-col gap-2">
                <label class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">Engine Power (kW)</label>
                <input @bind="NewCar.EnginePowerKW" type="number" min="1" max="1500" class="bg-gray-50 dark:bg-slate-800/40 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-text-dark dark:text-text-light focus:border-primary focus:ring-2 focus:ring-primary/10 focus:outline-none transition-all duration-200 font-medium" placeholder="200" required />
            </div>

            <div class="flex flex-col gap-2">
                <label class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">Fuel Type</label>
                <select @bind="NewCar.FuelType" class="bg-gray-50 dark:bg-slate-800/40 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-text-dark dark:text-text-light focus:border-primary focus:ring-2 focus:ring-primary/10 focus:outline-none transition-all duration-200 font-medium">
                    <option value="0">Petrol</option>
                    <option value="1">Diesel</option>
                    <option value="2">Electric</option>
                    <option value="3">Hybrid</option>
                    <option value="4">Plug-in Hybrid</option>
                </select>
            </div>

            <div class="flex flex-col gap-2">
                <label class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">Transmission</label>
                <select @bind="NewCar.Transmission" class="bg-gray-50 dark:bg-slate-800/40 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-text-dark dark:text-text-light focus:border-primary focus:ring-2 focus:ring-primary/10 focus:outline-none transition-all duration-200 font-medium">
                    <option value="0">Manual</option>
                    <option value="1">Automatic</option>
                    <option value="2">Semi-Automatic</option>
                </select>
            </div>

            <div class="flex flex-col gap-2">
                <label class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">Body Type</label>
                <select @bind="NewCar.BodyType" class="bg-gray-50 dark:bg-slate-800/40 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-text-dark dark:text-text-light focus:border-primary focus:ring-2 focus:ring-primary/10 focus:outline-none transition-all duration-200 font-medium">
                    <option value="0">Sedan</option>
                    <option value="1">Estate</option>
                    <option value="2">Hatchback</option>
                    <option value="3">SUV</option>
                    <option value="4">Coupe</option>
                    <option value="5">Minivan</option>
                </select>
            </div>

            <div class="flex flex-col gap-2 md:col-span-2">
                <label class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">Primary Image URL</label>
                <input @bind="NewCar.PrimaryImagePath" class="bg-gray-50 dark:bg-slate-800/40 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-text-dark dark:text-text-light focus:border-primary focus:ring-2 focus:ring-primary/10 focus:outline-none transition-all duration-200 font-medium" placeholder="https://example.com/car.jpg" required />
            </div>

            <div class="flex flex-col gap-2 md:col-span-2">
                <label class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">Description</label>
                <textarea @bind="NewCar.Description" class="bg-gray-50 dark:bg-slate-800/40 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-text-dark dark:text-text-light focus:border-primary focus:ring-2 focus:ring-primary/10 focus:outline-none transition-all duration-200 font-medium" rows="3" placeholder="Describe your car (10-1000 characters)..." minlength="10" maxlength="1000"></textarea>
            </div>

            <div class="flex flex-col gap-2 md:col-span-2">
                <label class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">Location</label>
                <input @bind="NewCar.Location" class="bg-gray-50 dark:bg-slate-800/40 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-text-dark dark:text-text-light focus:border-primary focus:ring-2 focus:ring-primary/10 focus:outline-none transition-all duration-200 font-medium" placeholder="e.g., Vilnius" required />
            </div>

            <div class="flex flex-col gap-2 md:col-span-2">
                <label class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest">Contact Info (Email) <span class="text-slate-500 dark:text-slate-400 font-normal">(Optional)</span></label>
                <input @bind="NewCar.ContactInfo" type="email" class="bg-gray-50 dark:bg-slate-800/40 border border-slate-200 dark:border-slate-700 rounded-xl px-4 py-3 text-text-dark dark:text-text-light focus:border-primary focus:ring-2 focus:ring-primary/10 focus:outline-none transition-all duration-200 font-medium" placeholder="your@email.com" />
            </div>

            <div class="md:col-span-2">
                <button type="submit" disabled="@IsSubmitting" class="px-8 py-3 bg-primary text-[#022c22] rounded-full font-bold hover:bg-green-400 transition-all duration-200 shadow-lg shadow-primary/20 active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed">
                    @if (IsSubmitting)
                    {
                        <span>Adding Car...</span>
                    }
                    else
                    {
                        <span>Add Car</span>
                    }
                </button>
            </div>
        </form>
    </div>

    <!-- My Cars Section -->
    <div class="bg-white dark:bg-surface-dark p-8 rounded-2xl shadow-light-soft dark:shadow-soft border border-slate-200 dark:border-slate-800">
        <h3 class="text-xl font-bold mb-6 text-text-dark dark:text-text-light">My Cars</h3>

        @if (IsLoadingCars)
        {
            <p class="text-text-muted dark:text-gray-400">Loading cars...</p>
        }
        else if (!AddedCars.Any())
        {
            <p class="text-text-muted dark:text-gray-400">You haven't added any cars yet. Use the form above to add your first car!</p>
        }
        else
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                @foreach (var car in AddedCars)
                {
                    <div class="bg-gray-50 dark:bg-slate-800/40 p-4 rounded-xl border border-slate-200 dark:border-slate-700 hover:shadow-md transition-shadow">
                        <img src="@car.PrimaryImagePath" alt="@car.Brand @car.Model" class="w-full h-40 object-cover rounded-lg mb-3" onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22100%22 height=%22100%22%3E%3Crect fill=%22%23ccc%22 width=%22100%22 height=%22100%22/%3E%3Ctext x=%2250%25%22 y=%2250%25%22 dominant-baseline=%22middle%22 text-anchor=%22middle%22 font-family=%22Arial%22 font-size=%2214%22 fill=%22%23999%22%3ENo Image%3C/text%3E%3C/svg%3E'" />
                        <h4 class="font-bold text-text-dark dark:text-text-light">@car.Brand @car.Model</h4>
                        <p class="text-sm text-text-muted dark:text-gray-400">@car.ProductionYear • €@car.Price.ToString("N0")</p>
                        <p class="text-xs text-text-muted dark:text-gray-500 mt-2">@car.MileageKm km • @GetFuelType(car.FuelType)</p>
                        <div class="mt-4 flex gap-2">
                            <button @onclick="() => ViewCar(car.Id)" class="flex-1 px-3 py-2 bg-primary/10 text-primary hover:bg-primary/20 rounded-lg font-medium text-sm transition-colors">
                                View
                            </button>
                            <button @onclick="() => DeleteCar(car.Id)" disabled="@(IsDeletingId == car.Id)" class="flex-1 px-3 py-2 bg-red-500/10 text-red-600 hover:bg-red-500/20 rounded-lg font-medium text-sm transition-colors disabled:opacity-50">
                                @if (IsDeletingId == car.Id)
                                {
                                    <span>Deleting...</span>
                                }
                                else
                                {
                                    <span>Delete</span>
                                }
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

</div>

@code {
    private List<Shared.Models.Car> AddedCars { get; set; } = new();
    private Shared.Models.Car NewCar { get; set; } = new();

    private string? SuccessMessage { get; set; }
    private string? ErrorMessage { get; set; }
    private bool IsSubmitting { get; set; }
    private bool IsLoadingCars { get; set; }
    private string? IsDeletingId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadUserCars();
    }

    private async Task LoadUserCars()
    {
        try
        {
            IsLoadingCars = true;
            var allCars = await Garage.GetAllCarsAsync();
            AddedCars = allCars?.Where(c => !c.IsDemo).ToList() ?? new List<Shared.Models.Car>();
        }
        catch (Exception ex)
        {
            ErrorMessage = "Failed to load cars: " + ex.Message;
        }
        finally
        {
            IsLoadingCars = false;
        }
    }

    private async Task AddCar()
    {
        try
        {
            // Validate form data
            if (string.IsNullOrWhiteSpace(NewCar.Brand) || string.IsNullOrWhiteSpace(NewCar.Model))
            {
                ErrorMessage = "Brand and Model are required";
                return;
            }

            if (NewCar.ProductionYear < 1980 || NewCar.ProductionYear > 2026)
            {
                ErrorMessage = "Invalid production year";
                return;
            }

            // Set required fields
            if (string.IsNullOrEmpty(NewCar.Id))
            {
                NewCar.Id = $"{NewCar.Brand.ToLower()}-{NewCar.Model.ToLower()}-{Guid.NewGuid().ToString().Substring(0, 8)}";
            }

            NewCar.Features ??= new List<string>();
            NewCar.AdditionalImagePaths ??= new List<string>();

            // Optional fuel/energy consumption defaults
            if (NewCar.FuelType == Shared.Models.FuelCategory.Electric)
            {
                NewCar.EnergyConsumptionKWhPer100Km ??= 20.0;
            }
            else
            {
                NewCar.FuelConsumptionLitersPer100Km ??= 8.5;
            }

            IsSubmitting = true;
            ErrorMessage = null;

            // Send to API
            var success = await Garage.CreateCarAsync(NewCar);

            if (success)
            {
                SuccessMessage = $"Successfully added {NewCar.Brand} {NewCar.Model}!";
                AddedCars.Add(NewCar);
                NewCar = new Shared.Models.Car();
                StateHasChanged();

                // Clear success message after 3 seconds
                await Task.Delay(3000);
                SuccessMessage = null;
            }
            else
            {
                ErrorMessage = "Failed to add car. Please try again.";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = "Error adding car: " + ex.Message;
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private async Task DeleteCar(string id)
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to delete this car?"))
        {
            return;
        }

        try
        {
            IsDeletingId = id;
            StateHasChanged();

            var success = await Garage.DeleteCarAsync(id);

            if (success)
            {
                AddedCars.RemoveAll(c => c.Id == id);
                SuccessMessage = "Car deleted successfully";
                ErrorMessage = null;
                StateHasChanged();

                await Task.Delay(2000);
                SuccessMessage = null;
                StateHasChanged();
            }
            else
            {
                ErrorMessage = "Failed to delete car";
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = "Error deleting car: " + ex.Message;
            Console.WriteLine($"Delete error: {ex.Message}");
            StateHasChanged();
        }
        finally
        {
            IsDeletingId = null;
            StateHasChanged();
        }
    }

    private void ViewCar(string id)
    {
        Nav.NavigateTo($"/cars/{id}");
    }

    private string GetFuelType(Shared.Models.FuelCategory fuel) => fuel switch
    {
        Shared.Models.FuelCategory.Petrol => "🛢️ Petrol",
        Shared.Models.FuelCategory.Diesel => "🛢️ Diesel",
        Shared.Models.FuelCategory.Electric => "⚡ Electric",
        Shared.Models.FuelCategory.Hybrid => "⚡ Hybrid",
        Shared.Models.FuelCategory.PlugInHybrid => "⚡ Plug-in Hybrid",
        _ => "Unknown"
    };

    [Inject]
    private IJSRuntime JSRuntime { get; set; } = null!;
}
