@page "/profile"

<div class="profile-container">

    <h2 class="title-gradient">Profile Settings</h2>

    <div class="profile-card">

        <div class="profile-image">
            <img src="https://images.unsplash.com/photo-1503376780353-7e6692767b70" />
        </div>

        <div class="profile-info">
            <h3>Your Car</h3>

            <div class="profile-field">
                <label>Brand</label>
                <input class="form-control" placeholder="BMW" />
            </div>

            <div class="profile-field">
                <label>Model</label>
                <input class="form-control" placeholder="M3" />
            </div>

            <div class="profile-field">
                <label>Year</label>
                <input class="form-control" placeholder="2020" />
            </div>

            <div class="profile-field">
                <label>Mileage</label>
                <input class="form-control" placeholder="45000 km" />
            </div>

            <button class="save-btn">
                Save Changes
            </button>

        </div>

    </div>

</div>