@page "/comparison"
@inject CarService Garage

<div class="page-container">

    <h2 class="title-gradient">Car Comparison</h2>

    @if (Garage.MatchedCars.Count < 2)
    {
        <div class="compare-empty">
            Select at least two cars to compare.
        </div>
    }
    else
    {
        var car1 = Garage.MatchedCars[0];
        var car2 = Garage.MatchedCars[1];

        <div class="compare-container">

            <div class="compare-card">
                <img src="@car1.PrimaryImagePath" class="compare-img" />
                <h3>@car1.Brand @car1.Model</h3>
            </div>

            <div class="compare-card">
                <img src="@car2.PrimaryImagePath" class="compare-img" />
                <h3>@car2.Brand @car2.Model</h3>
            </div>

        </div>

        <table class="compare-table">

            <tr>
                <th>Specification</th>
                <th>@car1.Brand @car1.Model</th>
                <th>@car2.Brand @car2.Model</th>
            </tr>

            <tr>
                <td>Year</td>
                <td>@car1.ProductionYear</td>
                <td>@car2.ProductionYear</td>
            </tr>

            <tr>
                <td>Fuel</td>
                <td>@car1.FuelType</td>
                <td>@car2.FuelType</td>
            </tr>

            <tr>
                <td>Transmission</td>
                <td>@car1.Transmission</td>
                <td>@car2.Transmission</td>
            </tr>

            <tr>
                <td>Body</td>
                <td>@car1.BodyType</td>
                <td>@car2.BodyType</td>
            </tr>

            <tr>
                <td>Power (kW)</td>
                <td>@car1.EnginePowerKW</td>
                <td>@car2.EnginePowerKW</td>
            </tr>

            <tr>
                <td>Fuel Consumption</td>
                <td>@car1.FuelConsumptionLitersPer100Km</td>
                <td>@car2.FuelConsumptionLitersPer100Km</td>
            </tr>

            <tr>
                <td>Price</td>
                <td>€@car1.Price</td>
                <td>€@car2.Price</td>
            </tr>

            <tr>
                <td>Mileage</td>
                <td>@car1.MileageKm km</td>
                <td>@car2.MileageKm km</td>
            </tr>

            <tr>
                <td>Location</td>
                <td>@car1.Location</td>
                <td>@car2.Location</td>
            </tr>

        </table>
    }

</div>